# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/queen-gold
# Production example:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/queen-gold?retryWrites=true&w=majority

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-to-a-long-random-string-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── Admin Seed (used by scripts/seed.ts) ────────────────────────────────────
ADMIN_EMAIL=admin@queengold.com
ADMIN_PASSWORD=ChangeMe@2025!

# ─── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Rate Limiting (in-memory by default; set REDIS_URL for production) ───────
# REDIS_URL=redis://localhost:6379
