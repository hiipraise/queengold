# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/queen-gold
# Production:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/queen-gold?retryWrites=true&w=majority

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-to-a-long-random-string-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── Admin Seed ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@queengold.com
ADMIN_PASSWORD=ChangeMe@2025!

# ─── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Squad by GTBank Payment ──────────────────────────────────────────────────
# Get keys from https://dashboard.squadco.com/
SQUAD_SECRET_KEY=sandbox_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SQUAD_PUBLIC_KEY=sandbox_pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set to "live" for production, leave unset or "sandbox" for testing
SQUAD_ENV=sandbox

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
